{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr list:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)"
    ],
    "deny": [
      "Bash(git push:* --force*)",
      "Bash(git reset:* --hard*)",
      "Bash(rm -rf:*)"
    ]
  }
}
